class Solution {
    public boolean isAnagram(String s, String t) {
         int[] crt=new int[26];
         if(s.length()!= t.length()) return false;

         for(int i=0;i<s.length();i++){
            crt[s.charAt(i)-'a']++;
         }

          for(int i=0;i<t.length();i++){
            crt[t.charAt(i)-'a']--;
         }
         for(int i=0;i<crt.length;i++)
         {
           if(crt[i]!=0) return false;
         }
         return true;

        }
    }

